  "query": "SELECT b.id, b.player_uuid, p.username, b.reason, b.banned_by, b.banned_at, b.expires_at FROM player_bans b LEFT JOIN players p ON p.uuid=b.player_uuid WHERE b.active=1 AND (b.expires_at IS NULL OR b.expires_at > NOW()) ORDER BY b.banned_at DESC",
